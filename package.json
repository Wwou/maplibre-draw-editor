{
  "name": "maplibre-draw-editor",
  "private": false,
  "version": "0.0.5",
  "type": "module",
  "description": "基于 MapLibre GL JS 的绘制和编辑工具",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "maplibre",
    "draw",
    "editor",
    "map",
    "maplibre-gl"
  ],
  "author": "wou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wwou/maplibre-draw-editor.git"
  },
  "peerDependencies": {
    "maplibre-gl": "^5.22.0",
    "vue": "^3.5.32"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "maplibre-gl": "^5.22.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^3.9.0",
    "vue-tsc": "^3.2.6"
  }
}
